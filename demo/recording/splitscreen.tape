# vhs tape — the split-screen money shot (scan · GPU · zero egress).
# Render:  PATH="$PWD/.tmp/bin:$PATH" vhs demo/recording/splitscreen.tape
Output demo/recording/splitscreen.gif
Set FontSize 13
Set Width 1500
Set Height 860
Set Theme "Dracula"
Set Padding 12

Type "bash demo/recording/splitscreen.sh"
Enter
Sleep 14s
