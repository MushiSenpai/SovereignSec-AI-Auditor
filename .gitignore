# venvs / caches
.venv/
.venv-train/
.tmp/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# local DBs / scan artifacts
*.db
app.db
*.sqlite

# data moat outputs + mined corpora (the private moat — never commit bodies)
ft-rig/data/out/
data/out/
*.jsonl.gz
advdb/
CVEfixes.db
wheels/

# model weights / adapters / exports (huge; live outside git)
models/
*.gguf
*.safetensors
out/
loras/

# benchmark raw captures (keep the summarized reports, not the raw streams)
bench/results/*.raw
bench/results/*.tmp

# recordings — keep tapes/scripts; heavy video formats stay out.
# The demo GIFs ARE tracked (force-added with `git add -f`) so the README/docs embeds
# render on GitHub; the *.gif rule below only keeps NEW gifs from sneaking in untracked.
demo/recording/*.mp4
demo/recording/*.gif
demo/recording/*.webm
demo/recording/*.cast

# secrets / env
.env
*.key
*.pem
secrets/

# build artifacts / internal business docs (not for public)
unsloth_compiled_cache/
SCOPE.md
